# ===== قاعدة البيانات (Supabase / Postgres) =====
# من Supabase: Settings > Database > Connection string (URI). استخدم منفذ 6543 (pooler) لـ Vercel.
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
# اتصال مباشر (منفذ 5432) لعمليات prisma migrate / db push
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres"

# ===== المصادقة =====
# مفتاح سري لتوقيع جلسات JWT — ولّده بأمر:  openssl rand -base64 32
AUTH_SECRET="change-me-please-generate-a-long-random-secret"

# ===== عام =====
NEXT_PUBLIC_APP_NAME="منصة وئام للإصلاح الأسري"
